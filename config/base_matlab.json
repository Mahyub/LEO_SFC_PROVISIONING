{
  "scenario_id": "base_matlab",
  "num_satellites": 60,
  "orbital_planes": 4,
  "num_slices": 5,
  "users_per_slice": 10,
  "num_epochs": 15,
  "num_instances": 1,
  "random_seed_base": 42,

  "function_types": ["FW", "IDS", "ENC", "TM", "SIEM"],
  "sfc_length_range": [2, 4],
  "e2e_budget_range_ms": [75, 150],
  "criticality_C_range": [1.0, 3.0],
  "isl_delay_range_ms": [1.0, 5.0],
  "cpu_capacity_range": [40, 120],

  "sensitivity_R": {"FW": 0.6, "IDS": 0.8, "ENC": 0.9, "TM": 0.4, "SIEM": 0.6},
  "migration_cost_D": {"FW": 1.0, "IDS": 1.5, "ENC": 2.0, "TM": 0.8, "SIEM": 1.7},
  "activation_cpu_range": {"FW": [0.5, 1.2], "IDS": [1.0, 2.0], "ENC": [1.2, 2.5], "TM": [0.3, 0.8], "SIEM": [0.8, 1.8]},
  "per_user_cpu_range":   {"FW": [0.1, 0.3], "IDS": [0.2, 0.5], "ENC": [0.3, 0.6], "TM": [0.05, 0.2], "SIEM": [0.15, 0.4]},
  "policy_phi_range": [0.0, 1.0],

  "omega_cap": 0.3,
  "omega_risk": 0.5,
  "omega_mig": 0.2,

  "min_elevation_deg": 10.0,
  "slice_ground_stations": [
    {"lat":  51.5,  "lon":  -0.1,  "_name": "London"},
    {"lat":  40.7,  "lon": -74.0,  "_name": "New York"},
    {"lat":  35.7,  "lon": 139.7,  "_name": "Tokyo"},
    {"lat": -33.9,  "lon": 151.2,  "_name": "Sydney"},
    {"lat":  48.9,  "lon":   2.3,  "_name": "Paris"}
  ],

  "orbit_altitude_km": 550.0,
  "orbit_inclination_deg": 53.0,
  "walker_phasing": 1,
  "epoch_duration_s": 60.0,

  "isl_max_flows": 20,

  "sa_T0": 1.0,
  "sa_Tend": 0.01,
  "sa_iterations": 50000,
  "time_limit_s": 300,
  "time_limit_exact_s": 600,
  "run_exact_model": true,

  "matlab_bridge": {
    "matlab_script_dir": "matlab",
    "matlab_exe": "matlab",
    "mps_url": "http://localhost:9910/satcom/generateTopology",
    "bridge_mode": "auto",

    "walker_total_sats": 100,
    "walker_planes": 10,
    "_note": "walker_total_sats/walker_planes are overridden by top-level num_satellites/orbital_planes",
    "walker_phasing": 1,
    "orbit_altitude_km": 550.0,
    "orbit_inclination_deg": 53.0,

    "epoch_start_utc": "2025-01-01 00:00:00",
    "epoch_duration_s": 60.0,

    "isl_model": "nearest_k",
    "isl_k": 4,
    "isl_max_range_km": 2500.0,
    "matlab_subprocess_timeout_s": 600,

    "cache_file": "data/topology_cache.json",
    "save_user_visibility": false
  }
}